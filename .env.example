# -----------------------------------------------------------------------
# These are NOT read automatically by Cloudflare Workers at runtime.
# Cloudflare Workers use `wrangler secret put <NAME>` for secrets instead
# of a .env file (see README "Environment Variables" section).
#
# This file exists for two purposes:
#   1. Documentation of which values you need to gather.
#   2. Local use by scripts/set-webhook.mjs and scripts/delete-webhook.mjs,
#      which DO read process.env directly (export these in your shell, or
#      use a tool like `dotenv-cli` / `source .env` before running them).
# -----------------------------------------------------------------------

# Telegram bot token from @BotFather
BOT_TOKEN=123456789:AAExampleTokenReplaceMe

# A random secret string YOU choose. Used to verify that webhook requests
# actually come from Telegram (sent back as X-Telegram-Bot-Api-Secret-Token).
# Generate one with: openssl rand -hex 24
WEBHOOK_SECRET=replace-with-a-long-random-string

# Your deployed Worker URL, filled in after `npm run deploy`
# e.g. https://cisco-cli-assistant-bot.yourname.workers.dev
WORKER_URL=https://cisco-cli-assistant-bot.YOUR-SUBDOMAIN.workers.dev

# Optional: enables the AI fallback layer for unmatched queries.
# Leave blank to run the bot in "catalog-only" mode (never guesses).
AI_API_KEY=
