# ---- Telegram ----
# Get this from @BotFather on Telegram (see README.md for step-by-step setup)
BOT_TOKEN=123456789:AAExampleTokenReplaceThisWithYourRealTokenFromBotFather

# Comma-separated Telegram user IDs allowed admin-only features (currently unused, reserved)
ADMIN_IDS=

# ---- Logging ----
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log

# ---- Search tuning ----
# 0.0 - 1.0, higher = stricter fuzzy/misspelling matching
FUZZY_THRESHOLD=0.6
MAX_RESULTS=8
HISTORY_LIMIT=20

# ---- AI fallback layer ----
# Only used when the local database search finds nothing. The AI is
# constrained to picking among existing database entries -- it can
# never invent a new Cisco command. See app/ai.py.
AI_ENABLED=false
AI_PROVIDER=anthropic
# AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
